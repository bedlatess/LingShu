APP_ENV=development
APP_PORT=8080
APP_PUBLIC_URL=http://localhost:8080

DATABASE_URL=postgres://lingshu:lingshu@localhost:5432/lingshu?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# docker-compose 用：postgres 容器密码（compose 会注入到 app 的 DATABASE_URL）
POSTGRES_PASSWORD=lingshu

JWT_SECRET=change-me
KEY_ENCRYPTION_SECRET=change-me-32-bytes

DEFAULT_RATE_MULTIPLIER=1.2
API_KEY_PREFIX=lsk_live_
REGISTRATION_ENABLED=false
DEFAULT_USER_RPM_LIMIT=60
DEFAULT_USER_CONCURRENCY_LIMIT=5
DEFAULT_GATEWAY_TIMEOUT_SECONDS=120

ADMIN_USER=admin
ADMIN_PASS=change-me

